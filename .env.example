# ---- App ----
NODE_ENV=development
LOG_LEVEL=info

# ---- Database (Postgres) ----
# Local: postgresql://USER:PASS@localhost:5432/pardeep
# Hosted: copy connection string from Supabase / Neon / RDS
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pardeep

# ---- NextAuth ----
# Generate with: openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET=replace_me_with_a_32_char_random_string
# Required in production; auto-detected in dev
# AUTH_URL=https://your-domain.com

# ---- OAuth (optional) ----
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
